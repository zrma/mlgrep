package search

test MatchesLiteralSubstring() {
    line := "ERROR timeout"
    needle := "ERROR"
    assert(Matches(con line, con needle))
}

test MatchesUnicodeText() {
    text := "오류 가나다"
    needle := "오류"
    assert(Matches(con text, con needle))
}

test RejectsMissingSubstring() {
    text := "INFO ready"
    needle := "ERROR"
    assert(!Matches(con text, con needle))
}

test EmptyPatternMatchesEveryLine() {
    text := "first"
    needle := ""
    assert(Matches(con text, con needle))
}
